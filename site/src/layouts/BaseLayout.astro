---
import { siteConfig } from "../../site.config";
import { fontsUrl } from "../utils/config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { getLocale } from "../i18n/t";
import { organizationSchema, websiteSchema } from "../lib/structured-data";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  jsonLd?: object | object[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  publishedTime,
  jsonLd,
  noIndex = false,
} = Astro.props;

const locale = getLocale(Astro.url);
const htmlLang = locale === "fr" ? "fr-FR" : "en-US";
const ogLocale = locale === "fr" ? "fr_FR" : "en_US";

const imageUrl = ogImage?.startsWith("http") ? ogImage : `${siteConfig.url}${ogImage}`;
const baseJsonLd = [organizationSchema(), websiteSchema(locale)];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [...baseJsonLd, ...pageJsonLd];

const cleanPath = Astro.url.pathname.replace(/^\/fr/, "") || "/";
const enHref = siteConfig.url + cleanPath;
const frHref = siteConfig.url + "/fr" + (cleanPath === "/" ? "/" : cleanPath);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl()} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content={siteConfig.author} />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Hreflang (bilingual EN + FR) -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteConfig.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Analytics tracker -->
    <script src="/tracker.js" defer is:inline></script>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#7C3AED" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} - The Lab`} href="/rss.xml" />

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />

    <!-- Scroll reveal observer -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll(".reveal, .reveal-children, .scale-reveal");
        if (!els.length) return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("visible");
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach(function (el) { observer.observe(el); });
      })();
    </script>
  </body>
</html>
