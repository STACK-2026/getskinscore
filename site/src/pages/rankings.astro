---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../data/products";
import { siteConfig } from "../../site.config";
import { fullUrl, gradeClass, BUILD_DATE_ISO, updatedLabel } from "../utils/config";
import { jsonLdBreadcrumbs, jsonLdDataset, jsonLdFaq } from "../utils/seo";
import { getLocale, t, tr, localizedPath } from "../i18n/t";

const locale = getLocale(Astro.url);
const sorted = [...products].sort((a, b) => b.scoreNumeric - a.scoreNumeric);
const aCount = sorted.filter((p) => p.score === "A").length;

const breadcrumbs = [
  { name: t(tr.common.home, locale), url: fullUrl(localizedPath("/", locale)) },
  { name: t(tr.nav.rankings, locale), url: fullUrl(localizedPath("/rankings", locale)) },
];

const rankingsUrl = fullUrl(localizedPath("/rankings", locale));

// Dataset schema: sorted.length and aCount are both displayed on this page.
const datasetSchema = jsonLdDataset({
  url: rankingsUrl,
  dateModified: BUILD_DATE_ISO,
  inLanguage: locale === "fr" ? "fr-FR" : "en-US",
  description: locale === "fr"
    ? `Classement SkinScore de ${sorted.length} produits skincare notes de A a E sur cinq dimensions ponderees, dont ${aCount} produits notes A.`
    : `SkinScore ranking of ${sorted.length} skincare products graded A to E across five weighted dimensions, including ${aCount} A-rated products.`,
});

const faqItems = locale === "fr"
  ? [
      { question: "À quelle fréquence le classement est-il recalculé ?", answer: `Le classement couvre ${sorted.length} produits et chaque score est recalculé dès qu'un fabricant modifie sa formulation INCI, dans une fenêtre typique de 10 jours. La date de mise à jour est affichée en haut de cette page.` },
      { question: "Pourquoi un produit obtient-il un B et pas un A ?", answer: "Un B (70 à 84) signifie un compromis mineur sur l'une des cinq dimensions : un actif efficace mais un peu de parfum, ou une formule sûre mais sans concentration déclarée. Un A (85 à 100) exige l'excellence sur les cinq axes simultanément." },
      { question: "Comment lire le classement pour mon type de peau ?", answer: "Un score global élevé ne garantit pas l'adéquation à ta peau. Ouvre la fiche produit et vérifie le sous-score compatibilité peau pour ton profil (sèche, grasse, mixte, sensible, normale) avant d'acheter." },
    ]
  : [
      { question: "How often is the ranking recalculated?", answer: `The ranking covers ${sorted.length} products and each score is recomputed as soon as a manufacturer changes the INCI list, within a typical 10-day window. The update date is shown at the top of this page.` },
      { question: "Why does a product get a B and not an A?", answer: "A B (70 to 84) means a minor compromise on one of the five dimensions: an effective active but some fragrance, or a safe formula with no declared concentration. An A (85 to 100) requires excellence across all five dimensions at once." },
      { question: "How do I read the ranking for my skin type?", answer: "A high overall score does not guarantee a fit for your skin. Open the product page and check the skin-type fit sub-score for your profile (dry, oily, combination, sensitive, normal) before buying." },
    ];

const faqSchema = jsonLdFaq(faqItems);
---

<BaseLayout
  title={`Skincare Rankings - Best Products Rated A to E | ${siteConfig.name}`}
  description="Independent skincare product rankings. Every product scored from A to E across efficacy, safety, comedogenicity, transparency, and skin-type fit. Science-backed, brand-independent."
  jsonLd={[jsonLdBreadcrumbs(breadcrumbs), datasetSchema, faqSchema]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-8">
      <h1 class="mb-3">{locale === "fr" ? "Classement skincare" : "Skincare rankings"}</h1>
      <p class="text-slate-600 max-w-2xl mx-auto">
        {locale === "fr"
          ? `${sorted.length} produits notés de A à E. Indépendant, basé sur la science, jamais influencé par les marques.`
          : `${sorted.length} products rated from A to E. Independent, science-backed, never influenced by brands.`}
      </p>
      <p class="text-xs text-slate-500 mt-3">
        {locale === "fr"
          ? `${aCount} produits notés A · scores recalculés mensuellement · ${updatedLabel("fr")}`
          : `${aCount} A-rated products · scores recalculated monthly · ${updatedLabel("en")}`}
      </p>
    </div>

    <aside data-speakable aria-label="TL;DR" class="max-w-3xl mx-auto mb-10 rounded-xl border border-violet-200 bg-violet-50/60 px-6 py-5 text-slate-700">
      <p class="text-xs font-bold uppercase tracking-wider text-violet-700 mb-2">TL;DR</p>
      <p class="text-[15px] leading-relaxed">
        {locale === "fr" ? (
          <><strong>Le classement SkinScore</strong> note chaque produit de A (85 à 100) à E (0 à 39) sur cinq axes : efficacité (actifs prouvés), sécurité (allergènes, perturbateurs endocriniens), comédogénicité, transparence (INCI complète) et compatibilité avec ton type de peau. Les données proviennent d'EU CosIng, des avis SCCS et de la recherche dermatologique revue par les pairs. Aucune marque ne nous paie. La Mer obtient un C, on s'en fiche.</>
        ) : (
          <><strong>SkinScore rankings</strong> grade every product from A (85 to 100) down to E (0 to 39) across five dimensions: efficacy (proven actives), safety (allergens, endocrine disruptors), comedogenicity, transparency (full INCI), and skin-type fit. Data comes from EU CosIng, SCCS opinions, and peer-reviewed dermatology research. No brand pays us. La Mer gets a C. We don't care.</>
        )}
      </p>
    </aside>

    <div class="max-w-3xl mx-auto mb-10 text-slate-600 leading-relaxed space-y-4">
      {locale === "fr" ? (
        <>
          <p>Pour utiliser ce classement, repère d'abord ta catégorie de produit (nettoyant, sérum, hydratant, exfoliant) via les scores globaux. Un grade A ne signifie pas que le produit sera parfait pour toi : regarde le sous-score "compatibilité" selon ton type de peau (sèche, grasse, sensible, mixte, normale). Un score global de 85 sur un produit noté D en compatibilité peau sensible reste un mauvais choix si ta peau réagit.</p>
          <p>Les seuils sont stricts : A = 85 à 100 (excellent, à peu près irréprochable), B = 70 à 84 (très bon, quelques compromis mineurs), C = 55 à 69 (correct, mais mieux ailleurs), D = 40 à 54 (évite pour ton type de peau), E = 0 à 39 (formulation problématique). Les scores sont recalculés dès qu'un fabricant change sa formulation INCI.</p>
        </>
      ) : (
        <>
          <p>To use this ranking, first locate your product category (cleanser, serum, moisturiser, exfoliant) via the overall scores. A grade of A does not mean the product will be perfect for you: check the "skin-type fit" sub-score against your own profile (dry, oily, sensitive, combination, normal). A global 85 on a product that rates D for sensitive skin is still a bad pick if your skin reacts.</p>
          <p>The thresholds are strict: A = 85 to 100 (excellent, near-flawless), B = 70 to 84 (very good, minor compromises), C = 55 to 69 (acceptable, better options exist), D = 40 to 54 (avoid for your skin type), E = 0 to 39 (problematic formulation). Scores are recomputed whenever a manufacturer changes the INCI list.</p>
        </>
      )}
    </div>

    <div class="space-y-3">
      {sorted.map((p, i) => (
        <a
          href={localizedPath(`/product/${p.id}`, locale)}
          class="card card-glow flex items-center gap-4 !p-4"
        >
          <span class="text-sm text-slate-400 w-6 text-right font-bold shrink-0">{i + 1}</span>
          <div class={`grade grade-md ${gradeClass(p.score)} shrink-0`}>{p.score}</div>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <span class="text-xs text-violet-600 font-semibold">{p.brand}</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 capitalize">{p.type}</span>
            </div>
            <p class="text-sm font-bold text-slate-800 truncate">{p.name}</p>
          </div>
          <div class="text-right shrink-0 hidden sm:block">
            <p class="text-sm font-bold text-slate-800">{p.scoreNumeric}/100</p>
            <div class="flex gap-1 mt-1">
              {p.concerns.slice(0, 2).map((c) => (
                <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-violet-50 text-violet-600">{c}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Browse by category (internal linking hubs to /best/<concern>/) -->
    <div class="mt-16 pt-12 border-t border-slate-200">
      <h2 class="text-xl font-bold mb-6">
        {locale === "fr" ? "Parcourir par préoccupation" : "Browse by concern"}
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-12">
        {siteConfig.concerns
          .filter((c) => products.some((p) => p.concerns.includes(c.id)))
          .map((c) => (
            <a
              href={localizedPath(`/best/${c.id}`, locale)}
              class="card card-glow !p-4 text-center hover:border-violet-400"
            >
              <p class="text-sm font-bold text-slate-800">{c.label[locale]}</p>
              <p class="text-xs text-slate-500 mt-1">
                {products.filter((p) => p.concerns.includes(c.id)).length}
                {locale === "fr" ? " produits" : " products"}
              </p>
            </a>
          ))}
      </div>

      <h2 class="text-xl font-bold mb-6">
        {locale === "fr" ? "Parcourir par type de produit" : "Browse by product type"}
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {siteConfig.productTypes
          .filter((pt) => products.some((p) => p.type === pt.id))
          .map((pt) => {
            // Pick the most-stocked concern for this type to deep-link to /best/<type>-<concern>/
            const typeProducts = products.filter((p) => p.type === pt.id);
            const concernCounts: { [key: string]: number } = {};
            for (const p of typeProducts) {
              for (const c of p.concerns) concernCounts[c] = (concernCounts[c] || 0) + 1;
            }
            const topConcern = Object.entries(concernCounts).sort((a, b) => b[1] - a[1])[0]?.[0];
            const href = topConcern
              ? localizedPath(`/best/${pt.id}-${topConcern}`, locale)
              : localizedPath(`/rankings`, locale);
            return (
              <a
                href={href}
                class="card card-glow !p-4 text-center hover:border-violet-400"
              >
                <p class="text-sm font-bold text-slate-800">{pt.label[locale]}</p>
                <p class="text-xs text-slate-500 mt-1">
                  {typeProducts.length}
                  {locale === "fr" ? " produits" : " products"}
                </p>
              </a>
            );
          })}
      </div>
    </div>

    <!-- FAQ: visible HTML in exact parity with FAQPage schema -->
    <div class="mt-16 pt-12 border-t border-slate-200 max-w-3xl mx-auto">
      <h2 class="text-xl font-bold mb-6">
        {locale === "fr" ? "Questions fréquentes" : "Frequently asked questions"}
      </h2>
      <div class="space-y-3">
        {faqItems.map((item, i) => (
          <details class="card !p-0 overflow-hidden" open={i === 0}>
            <summary class="flex items-center justify-between p-4 cursor-pointer font-bold text-sm text-slate-800 hover:text-violet-700">
              <span class="pr-4">{item.question}</span>
              <svg class="w-5 h-5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <div class="px-4 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
