---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ingredients } from "../../data/ingredients";
import { siteConfig } from "../../../site.config";
import { fullUrl, gradeClass } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";
import { t } from "../../i18n/t";

const sorted = [...ingredients].sort((a, b) => {
  const order = { A: 0, B: 1, C: 2, D: 3, E: 4 };
  return (order[a.score] || 5) - (order[b.score] || 5);
});
const categories = [...new Set(ingredients.map((i) => i.category))].sort();
const breadcrumbs = [
  { name: "Accueil", url: fullUrl("/fr/") },
  { name: "Ingrédients", url: fullUrl("/fr/encyclopedia") },
];
---

<BaseLayout
  title={`Encyclopédie des ingrédients · ${ingredients.length}+ ingrédients INCI décodés | ${siteConfig.name}`}
  description={`${ingredients.length} ingrédients INCI décodés. Chaque nom scientifique expliqué en langage clair avec score de sécurité et compatibilité peau.`}
  jsonLd={[jsonLdBreadcrumbs(breadcrumbs)]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-8">
      <h1 class="mb-3">Encyclopédie des ingrédients</h1>
      <p class="text-slate-600 max-w-2xl mx-auto">
        {ingredients.length} ingrédients INCI décodés. Chaque nom scientifique expliqué en langage clair.
      </p>
    </div>

    <aside data-speakable aria-label="TL;DR" class="max-w-3xl mx-auto mb-10 rounded-xl border border-violet-200 bg-violet-50/60 px-6 py-5 text-slate-700">
      <p class="text-xs font-bold uppercase tracking-wider text-violet-700 mb-2">TL;DR</p>
      <p class="text-[15px] leading-relaxed">
        <strong>L'encyclopédie SkinScore</strong> décode {ingredients.length} ingrédients INCI, chacun noté de A à E sur trois axes : sécurité (allergènes, perturbateurs endocriniens, restrictions UE), efficacité (preuves cliniques) et comédogénicité (risque d'obstruction des pores, échelle 0-5). Cherche un ingrédient par son nom INCI ou filtre par catégorie (actifs, conservateurs, émollients, tensioactifs). Données issues d'EU CosIng, SCCS et PubMed.
      </p>
    </aside>

    <div class="flex flex-wrap gap-2 mb-8 justify-center">
      {categories.map((cat) => (
        <span class="text-xs font-medium px-3 py-1.5 rounded-full bg-violet-50 text-violet-600 capitalize">
          {cat.replace("_", " ")} ({ingredients.filter((i) => i.category === cat).length})
        </span>
      ))}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {sorted.map((ing) => (
        <a href={`/fr/ingredient/${ing.id}`} class="card card-glow ingredient-glow flex items-start gap-3 !p-4">
          <div class={`grade grade-md ${gradeClass(ing.score)} shrink-0 mt-0.5`}>{ing.score}</div>
          <div class="min-w-0">
            <p class="text-xs text-slate-400 font-mono">{ing.inciName}</p>
            <h3 class="text-sm font-bold text-slate-800 mb-1">{t(ing.name, "fr")}</h3>
            <p class="text-xs text-slate-500 line-clamp-2">{t(ing.description, "fr").slice(0, 100)}...</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
