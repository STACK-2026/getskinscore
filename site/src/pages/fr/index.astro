---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomePage from "../../components/sections/HomePage.astro";
import { siteConfig } from "../../../site.config";
import { jsonLdHomepage, jsonLdFaq } from "../../utils/seo";
import { tr, t } from "../../i18n/t";

const faq = [
  { question: t(tr.faq.q1, "fr"), answer: t(tr.faq.a1, "fr") },
  { question: t(tr.faq.q2, "fr"), answer: t(tr.faq.a2, "fr") },
  { question: t(tr.faq.q3, "fr"), answer: t(tr.faq.a3, "fr") },
  { question: t(tr.faq.q4, "fr"), answer: t(tr.faq.a4, "fr") },
];

const jsonLd = [jsonLdHomepage(), jsonLdFaq(faq)];
---

<BaseLayout
  title={`${siteConfig.name} - Tes soins te mentent. On te dit la verite.`}
  description="67% des soins contiennent un ingredient douteux. SkinScore decode chaque ingredient, note chaque produit de A a E, et te dit la verite. Aucune marque ne nous paie. Jamais."
  jsonLd={jsonLd}
>
  <HomePage />
</BaseLayout>
