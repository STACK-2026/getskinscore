---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ingredients, type Ingredient } from "../../../data/ingredients";
import { products } from "../../../data/products";
import { siteConfig } from "../../../../site.config";
import { fullUrl, gradeClass } from "../../../utils/config";
import { jsonLdBreadcrumbs } from "../../../utils/seo";
import { t, tr } from "../../../i18n/t";

export function getStaticPaths() {
  return ingredients.map((i) => ({ params: { slug: i.id }, props: { ingredient: i } }));
}

const { ingredient } = Astro.props as { ingredient: Ingredient };
const locale = "fr";
const title = `${t(ingredient.name, locale)} - Score ${ingredient.score} | ${siteConfig.name}`;
const description = t(ingredient.description, locale).slice(0, 155) + "...";
const url = fullUrl(`/fr/ingredient/${ingredient.id}`);

const breadcrumbs = [
  { name: "Accueil", url: fullUrl("/fr/") },
  { name: "Ingredients", url: fullUrl("/fr/encyclopedia") },
  { name: t(ingredient.name, locale), url },
];

const containingProducts = products.filter((p) => p.ingredients.some((i) => i.ingredientId === ingredient.id)).sort((a, b) => b.scoreNumeric - a.scoreNumeric);

const skinTypeLabels: Record<string, string> = { dry: "Peau seche", oily: "Peau grasse", combination: "Peau mixte", sensitive: "Peau sensible", normal: "Peau normale" };
---

<BaseLayout title={title} description={description} jsonLd={[jsonLdBreadcrumbs(breadcrumbs)]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-xs text-slate-400 mb-8 flex items-center gap-1.5 flex-wrap">
      {breadcrumbs.map((item, i) => (<>{i > 0 && <span>/</span>}{i < breadcrumbs.length - 1 ? <a href={item.url} class="hover:text-violet-600">{item.name}</a> : <span class="text-slate-600">{item.name}</span>}</>))}
    </nav>

    <header class="flex items-start gap-6 mb-10">
      <div class={`grade grade-xl ${gradeClass(ingredient.score)} shrink-0`}>{ingredient.score}</div>
      <div>
        <p class="text-sm text-slate-400 font-mono mb-1">{ingredient.inciName}</p>
        <h1 class="text-2xl md:text-3xl mb-2">{t(ingredient.name, locale)}</h1>
        <div class="flex items-center gap-3 text-sm text-slate-500">
          <span class="px-2.5 py-0.5 rounded-full bg-violet-50 text-violet-600 font-medium capitalize">{ingredient.category.replace("_", " ")}</span>
          {ingredient.comedogenic > 0 && <span class="px-2.5 py-0.5 rounded-full bg-amber-50 text-amber-600 font-medium">Comedogene: {ingredient.comedogenic}/5</span>}
          {ingredient.euRestricted && <span class="px-2.5 py-0.5 rounded-full bg-red-50 text-red-600 font-medium">Reglemente UE</span>}
        </div>
      </div>
    </header>

    <div class="card mb-8"><p class="text-slate-600 leading-relaxed">{t(ingredient.description, locale)}</p></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="card !border-green-200 !bg-green-50/30">
        <h2 class="text-base font-bold text-green-800 mb-3">{t(tr.ingredient.benefits, locale)}</h2>
        <p class="text-sm text-green-900 leading-relaxed">{t(ingredient.benefits, locale)}</p>
      </div>
      <div class="card !border-orange-200 !bg-orange-50/30">
        <h2 class="text-base font-bold text-orange-800 mb-3">{t(tr.ingredient.risks, locale)}</h2>
        <p class="text-sm text-orange-900 leading-relaxed">{t(ingredient.risks, locale)}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {ingredient.goodFor.length > 0 && <div><h3 class="text-base font-bold mb-3">Ideal pour</h3><div class="flex flex-wrap gap-2">{ingredient.goodFor.map((st) => <span class="text-sm font-medium px-3 py-1.5 rounded-full bg-green-50 text-green-700">{skinTypeLabels[st]}</span>)}</div></div>}
      {ingredient.badFor.length > 0 && <div><h3 class="text-base font-bold mb-3">Eviter si</h3><div class="flex flex-wrap gap-2">{ingredient.badFor.map((st) => <span class="text-sm font-medium px-3 py-1.5 rounded-full bg-red-50 text-red-700">{skinTypeLabels[st]}</span>)}</div></div>}
    </div>

    {containingProducts.length > 0 && (
      <section>
        <h2 class="text-xl font-bold mb-4">Present dans ({containingProducts.length})</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {containingProducts.map((p) => (
            <a href={`/fr/product/${p.id}`} class="card card-glow flex items-center gap-4">
              <div class={`grade grade-md ${gradeClass(p.score)} shrink-0`}>{p.score}</div>
              <div class="min-w-0"><p class="text-xs text-violet-600 font-semibold">{p.brand}</p><p class="text-sm font-bold text-slate-800 truncate">{p.name}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
