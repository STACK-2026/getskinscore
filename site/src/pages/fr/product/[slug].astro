---
// FR mirror - reuses the same EN product page component logic
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { products, type Product } from "../../../data/products";
import { getIngredient } from "../../../data/ingredients";
import { siteConfig } from "../../../../site.config";
import { fullUrl, gradeClass } from "../../../utils/config";
import { jsonLdProduct, jsonLdBreadcrumbs } from "../../../utils/seo";
import { t, tr } from "../../../i18n/t";

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props as { product: Product };
const locale = "fr";
const title = `${product.brand} ${product.name} - Score ${product.score} (${product.scoreNumeric}/100) | ${siteConfig.name}`;
const description = t(product.summary, locale).slice(0, 155) + "...";
const url = fullUrl(`/fr/product/${product.id}`);

const breadcrumbs = [
  { name: "Accueil", url: fullUrl("/fr/") },
  { name: "Classement", url: fullUrl("/fr/rankings") },
  { name: `${product.brand} ${product.name}`, url },
];

const alternatives = products
  .filter((p) => p.id !== product.id && p.type === product.type && p.scoreNumeric >= product.scoreNumeric - 10)
  .sort((a, b) => b.scoreNumeric - a.scoreNumeric).slice(0, 4);

const subScoreLabels = [
  { key: "efficacy", label: t(tr.product.efficacy, locale) },
  { key: "safety", label: t(tr.product.safety, locale) },
  { key: "comedogenicity", label: t(tr.product.comedogenicity, locale) },
  { key: "transparency", label: t(tr.product.transparency, locale) },
  { key: "skinTypeFit", label: t(tr.product.skinTypeFit, locale) },
];
---

<BaseLayout title={title} description={description} jsonLd={[jsonLdProduct({ name: product.name, brand: product.brand, description: t(product.summary, locale), url, score: product.score, scoreNumeric: product.scoreNumeric }), jsonLdBreadcrumbs(breadcrumbs)]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-xs text-slate-400 mb-8 flex items-center gap-1.5 flex-wrap">
      {breadcrumbs.map((item, i) => (<>{i > 0 && <span>/</span>}{i < breadcrumbs.length - 1 ? <a href={item.url} class="hover:text-violet-600">{item.name}</a> : <span class="text-slate-600">{item.name}</span>}</>))}
    </nav>

    <header class="flex flex-col sm:flex-row items-start gap-6 mb-10">
      <div class={`grade grade-xl ${gradeClass(product.score)} shrink-0`}>{product.score}</div>
      <div>
        <p class="text-sm text-violet-600 font-semibold mb-1">{product.brand}</p>
        <h1 class="text-2xl md:text-3xl mb-2">{product.name}</h1>
        <div class="flex items-center gap-3 text-sm text-slate-500">
          <span class="px-2.5 py-0.5 rounded-full bg-slate-100 font-medium capitalize">{product.type}</span>
          <span>{product.scoreNumeric}/100</span>
        </div>
      </div>
    </header>

    <div class="card mb-8"><p class="text-slate-600 leading-relaxed">{t(product.summary, locale)}</p></div>

    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4">{t(tr.product.subScores, locale)}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-3">
        {subScoreLabels.map(({ key, label }) => {
          const grade = product.subScores[key as keyof typeof product.subScores];
          return <div class="card !p-4 text-center"><div class={`grade grade-md ${gradeClass(grade)} mx-auto mb-2`}>{grade}</div><p class="text-xs font-medium text-slate-600">{label}</p></div>;
        })}
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="card !border-green-200 !bg-green-50/30">
        <h3 class="text-base font-bold text-green-800 mb-3">{t(tr.product.strengths, locale)}</h3>
        <ul class="space-y-2">{t(product.strengths, locale).map((s: string) => <li class="flex items-start gap-2 text-sm text-green-900"><svg class="w-4 h-4 mt-0.5 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>{s}</li>)}</ul>
      </div>
      <div class="card !border-orange-200 !bg-orange-50/30">
        <h3 class="text-base font-bold text-orange-800 mb-3">{t(tr.product.weaknesses, locale)}</h3>
        <ul class="space-y-2">{t(product.weaknesses, locale).map((w: string) => <li class="flex items-start gap-2 text-sm text-orange-900"><svg class="w-4 h-4 mt-0.5 text-orange-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>{w}</li>)}</ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4">{t(tr.product.ingredients, locale)}</h2>
      <div class="space-y-1">
        {product.ingredients.map((ing) => {
          const detail = ing.ingredientId ? getIngredient(ing.ingredientId) : null;
          return <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors">
            <span class="text-xs text-slate-400 w-5 text-right shrink-0">{ing.position}</span>
            {detail ? <span class={`grade grade-sm ${gradeClass(detail.score)} shrink-0`}>{detail.score}</span> : <span class="grade grade-sm bg-slate-200 text-slate-500 shrink-0">?</span>}
            <div class="min-w-0 flex-1">
              {detail ? <a href={`/fr/ingredient/${detail.id}`} class="text-sm font-medium text-slate-800 hover:text-violet-600">{ing.name}</a> : <span class="text-sm font-medium text-slate-800">{ing.name}</span>}
              {ing.percentage && <span class="text-xs text-violet-500 ml-2">{ing.percentage}%</span>}
            </div>
          </div>;
        })}
      </div>
    </section>

    {alternatives.length > 0 && (
      <section>
        <h2 class="text-xl font-bold mb-4">{t(tr.product.alternatives, locale)}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {alternatives.map((alt) => (
            <a href={`/fr/product/${alt.id}`} class="card card-glow flex items-center gap-4">
              <div class={`grade grade-md ${gradeClass(alt.score)} shrink-0`}>{alt.score}</div>
              <div class="min-w-0"><p class="text-xs text-violet-600 font-semibold">{alt.brand}</p><p class="text-sm font-bold text-slate-800 truncate">{alt.name}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
