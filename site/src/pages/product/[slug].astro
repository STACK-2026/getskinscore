---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products, type Product } from "../../data/products";
import { getIngredient } from "../../data/ingredients";
import { getStarContent } from "../../data/star-product-content";
import { siteConfig } from "../../../site.config";
import { fullUrl, gradeClass } from "../../utils/config";
import { jsonLdProduct, jsonLdBreadcrumbs, jsonLdFaq } from "../../utils/seo";
import { getLocale, t, tr, localizedPath } from "../../i18n/t";

export function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.id },
    props: { product: p },
  }));
}

const { product } = Astro.props as { product: Product };
const locale = getLocale(Astro.url);
const star = getStarContent(product.id);
const title = `${product.brand} ${product.name} - Score ${product.score} (${product.scoreNumeric}/100) | ${siteConfig.name}`;
const description = t(product.summary, locale).slice(0, 155) + "...";
const url = fullUrl(`/product/${product.id}`);

const breadcrumbs = [
  { name: t(tr.common.home, locale), url: fullUrl(localizedPath("/", locale)) },
  { name: t(tr.nav.rankings, locale), url: fullUrl(localizedPath("/rankings", locale)) },
  { name: `${product.brand} ${product.name}`, url },
];

const jsonLd = [
  jsonLdProduct({
    name: product.name,
    brand: product.brand,
    description: t(product.summary, locale),
    url,
    score: product.score,
    scoreNumeric: product.scoreNumeric,
  }),
  jsonLdBreadcrumbs(breadcrumbs),
  ...(star?.faq?.length ? [jsonLdFaq(star.faq.map((f) => ({ question: t(f.question, locale), answer: t(f.answer, locale) })))] : []),
];

// Find alternatives: same type, better or equal score, different brand
const alternatives = products
  .filter((p) => p.id !== product.id && p.type === product.type && p.scoreNumeric >= product.scoreNumeric - 10)
  .sort((a, b) => b.scoreNumeric - a.scoreNumeric)
  .slice(0, 4);

const subScoreLabels = [
  { key: "efficacy", label: t(tr.product.efficacy, locale) },
  { key: "safety", label: t(tr.product.safety, locale) },
  { key: "comedogenicity", label: t(tr.product.comedogenicity, locale) },
  { key: "transparency", label: t(tr.product.transparency, locale) },
  { key: "skinTypeFit", label: t(tr.product.skinTypeFit, locale) },
];

// data-speakable TL;DR for AI citation (ChatGPT, Perplexity, AI Overviews)
const summaryText = t(product.summary, locale)?.trim() || "";
const speakableCore = locale === "fr"
  ? `obtient ${product.score} (${product.scoreNumeric}/100) sur l'analyse cinq dimensions de SkinScore : efficacité, sécurité, comédogénicité, transparence, compatibilité avec ton type de peau.`
  : `scores ${product.score} (${product.scoreNumeric}/100) on SkinScore's five-dimension analysis: efficacy, safety, comedogenicity, transparency, and skin-type fit.`;
const speakableText = summaryText
  ? summaryText.split(". ").slice(0, 2).join(". ").replace(/\.+$/, "") + "."
  : "";

// Indexation policy: only pages with deep editorial content are indexable.
// STACK-2026 programmatic thin pages rule: products under the enrichment
// threshold are noindexed to protect crawl budget and Helpful Content signal.
const isEnriched = Boolean(star);
const noIndex = !isEnriched;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} noIndex={noIndex}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumbs -->
    <nav class="text-xs text-slate-400 mb-8 flex items-center gap-1.5 flex-wrap">
      {breadcrumbs.map((item, i) => (
        <>
          {i > 0 && <span>/</span>}
          {i < breadcrumbs.length - 1 ? (
            <a href={item.url} class="hover:text-violet-600 transition-colors">{item.name}</a>
          ) : (
            <span class="text-slate-600">{item.name}</span>
          )}
        </>
      ))}
    </nav>

    <!-- Hero -->
    <header class="relative mb-10">
      <div class="flex flex-col md:flex-row items-start gap-8">
        <!-- Product image -->
        {product.image ? (
          <div class="w-full md:w-48 shrink-0">
            <div class="relative aspect-square rounded-2xl bg-gradient-to-br from-violet-50 to-indigo-50 border border-violet-100/50 overflow-hidden flex items-center justify-center p-4">
              <img
                src={product.image}
                alt={`${product.brand} ${product.name}`}
                class="max-w-full max-h-full object-contain mix-blend-multiply"
                loading="eager"
                width="200"
                height="200"
              />
              <div class={`absolute top-3 left-3 grade grade-lg ${gradeClass(product.score)} shadow-lg`}>
                {product.score}
              </div>
            </div>
          </div>
        ) : (
          <div class="w-full md:w-48 shrink-0">
            <div class="aspect-square rounded-2xl bg-gradient-to-br from-violet-50 to-indigo-50 border border-violet-100/50 flex items-center justify-center">
              <div class={`grade grade-xl ${gradeClass(product.score)} shadow-lg`}>
                {product.score}
              </div>
            </div>
          </div>
        )}

        <!-- Product info -->
        <div class="flex-1 min-w-0">
          <a href={localizedPath(`/brand/${product.brand.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`, locale)} class="text-sm text-violet-600 font-semibold hover:text-violet-700 transition-colors mb-1 inline-block">
            {product.brand}
          </a>
          <h1 class="text-2xl md:text-3xl mb-3">{product.name}</h1>

          <!-- Score bar -->
          <div class="mb-4">
            <div class="flex items-center gap-3 mb-1.5">
              <span class="text-3xl font-extrabold text-gradient">{product.scoreNumeric}</span>
              <span class="text-sm text-slate-400">/100</span>
            </div>
            <div class="score-bar w-full max-w-xs">
              <div class="score-bar-fill" style={`width: ${product.scoreNumeric}%; background: ${product.scoreNumeric >= 85 ? 'var(--grade-a)' : product.scoreNumeric >= 70 ? 'var(--grade-b)' : product.scoreNumeric >= 55 ? 'var(--grade-c)' : 'var(--grade-d)'};`}></div>
            </div>
          </div>

          <div class="flex items-center gap-3 text-sm text-slate-500 flex-wrap">
            <span class="px-2.5 py-0.5 rounded-full bg-slate-100 font-medium capitalize">{product.type}</span>
            {product.size && <span class="px-2.5 py-0.5 rounded-full bg-slate-100">{product.size}</span>}
            {product.price && <span class="px-2.5 py-0.5 rounded-full bg-slate-100">~{product.price}EUR</span>}
            {product.country && <span class="px-2.5 py-0.5 rounded-full bg-slate-100">{product.country}</span>}
          </div>

          {product.claims && (
            <div class="flex flex-wrap gap-2 mt-3">
              {product.claims.fragranceFree && <span class="text-[10px] font-medium px-2.5 py-1 rounded-full bg-green-50 text-green-700 border border-green-200">Fragrance-free</span>}
              {product.claims.vegan && <span class="text-[10px] font-medium px-2.5 py-1 rounded-full bg-green-50 text-green-700 border border-green-200">Vegan</span>}
              {product.claims.crueltyFree && <span class="text-[10px] font-medium px-2.5 py-1 rounded-full bg-green-50 text-green-700 border border-green-200">Cruelty-free</span>}
              {product.claims.dermatologistTested && <span class="text-[10px] font-medium px-2.5 py-1 rounded-full bg-blue-50 text-blue-700 border border-blue-200">Dermatologist-tested</span>}
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- TL;DR data-speakable for AI citation (ChatGPT, Perplexity, AI Overviews) -->
    <aside data-speakable aria-label="TL;DR" class="mb-6 rounded-xl border border-violet-200 bg-violet-50/60 px-6 py-5 text-slate-700">
      <p class="text-xs font-bold uppercase tracking-wider text-violet-700 mb-2">TL;DR</p>
      <p class="text-[15px] leading-relaxed">
        <strong>{product.brand} {product.name}</strong> {speakableCore} {speakableText}
      </p>
    </aside>

    <!-- Dupes CTA: main conversion path on product pages -->
    <a
      href={localizedPath("/dupes", locale)}
      class="group flex items-center gap-4 mb-8 rounded-xl border border-amber-200 bg-gradient-to-r from-amber-50 to-amber-100/40 px-5 py-4 hover:border-amber-300 hover:shadow-md transition-all"
    >
      <span class="shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-full bg-amber-200/70 text-amber-700 text-lg">&euro;</span>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-bold text-amber-900">
          {locale === "fr" ? `Moins cher pour les mêmes actifs que ${product.brand} ${product.name} ?` : `Same actives as ${product.brand} ${product.name} for less?`}
        </p>
        <p class="text-xs text-amber-700/80">
          {locale === "fr" ? "On compare les formules INCI, pas les prix. Trouve l'alternative validée." : "We compare INCI formulas, not prices. Find the validated alternative."}
        </p>
      </div>
      <span class="shrink-0 text-sm font-semibold text-amber-700 group-hover:translate-x-0.5 transition-transform">
        {locale === "fr" ? "Trouver un dupe →" : "Find a dupe →"}
      </span>
    </a>

    <!-- Summary -->
    <div class="card mb-8">
      <p class="text-slate-600 leading-relaxed">{t(product.summary, locale)}</p>
    </div>

    <!-- Sub-scores -->
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4">{t(tr.product.subScores, locale)}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-3">
        {subScoreLabels.map(({ key, label }) => {
          const grade = product.subScores[key as keyof typeof product.subScores];
          return (
            <div class="card !p-4 text-center">
              <div class={`grade grade-md ${gradeClass(grade)} mx-auto mb-2`}>{grade}</div>
              <p class="text-xs font-medium text-slate-600">{label}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Strengths & Weaknesses -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="card !border-green-200 !bg-green-50/30">
        <h3 class="text-base font-bold text-green-800 mb-3">{t(tr.product.strengths, locale)}</h3>
        <ul class="space-y-2">
          {t(product.strengths, locale).map((s: string) => (
            <li class="flex items-start gap-2 text-sm text-green-900">
              <svg class="w-4 h-4 mt-0.5 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
              {s}
            </li>
          ))}
        </ul>
      </div>
      <div class="card !border-orange-200 !bg-orange-50/30">
        <h3 class="text-base font-bold text-orange-800 mb-3">{t(tr.product.weaknesses, locale)}</h3>
        <ul class="space-y-2">
          {t(product.weaknesses, locale).map((w: string) => (
            <li class="flex items-start gap-2 text-sm text-orange-900">
              <svg class="w-4 h-4 mt-0.5 text-orange-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
              {w}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Full ingredient list -->
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4">{t(tr.product.ingredients, locale)}</h2>
      <div class="space-y-1">
        {product.ingredients.map((ing) => {
          const detail = ing.ingredientId ? getIngredient(ing.ingredientId) : null;
          return (
            <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 transition-colors border border-transparent hover:border-slate-200">
              <span class="text-xs text-slate-400 w-5 text-right shrink-0">{ing.position}</span>
              {detail ? (
                <span class={`grade grade-sm ${gradeClass(detail.score)} shrink-0`}>{detail.score}</span>
              ) : (
                <span class="grade grade-sm bg-slate-200 text-slate-500 shrink-0">?</span>
              )}
              <div class="min-w-0 flex-1">
                {detail ? (
                  <a href={localizedPath(`/ingredient/${detail.id}`, locale)} class="text-sm font-medium text-slate-800 hover:text-violet-600 transition-colors">
                    {ing.name}
                  </a>
                ) : (
                  <span class="text-sm font-medium text-slate-800">{ing.name}</span>
                )}
                {ing.percentage && <span class="text-xs text-violet-500 ml-2">{ing.percentage}%</span>}
              </div>
              {detail && <span class="text-[10px] text-slate-400 capitalize hidden sm:inline">{detail.category}</span>}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Best for -->
    <section class="mb-10">
      <h3 class="text-base font-bold mb-3">{locale === "fr" ? "Ideal pour" : "Best for"}</h3>
      <div class="flex flex-wrap gap-2">
        {product.bestFor.map((st) => (
          <span class="text-sm font-medium px-3 py-1 rounded-full bg-violet-50 text-violet-700 capitalize">{st} {locale === "fr" ? "peau" : "skin"}</span>
        ))}
        {product.concerns.map((c) => (
          <a href={localizedPath(`/best/${c}`, locale)} class="text-sm font-medium px-3 py-1 rounded-full bg-amber-50 text-amber-700 capitalize hover:bg-amber-100 transition-colors">{c}</a>
        ))}
      </div>
    </section>

    <!-- Star product deep content -->
    {star && (
      <div class="space-y-8 mb-10">
        <!-- Editorial review -->
        <section class="card !bg-violet-50/30 !border-violet-200/50">
          <h2 class="text-lg font-bold text-violet-900 mb-3">
            {locale === "fr" ? "Notre avis complet" : "Our full review"}
          </h2>
          <p class="text-slate-700 leading-relaxed">{t(star.editorialReview, locale)}</p>
        </section>

        <!-- How to use -->
        <section>
          <h2 class="text-lg font-bold mb-3">
            {locale === "fr" ? "Comment l'utiliser" : "How to use"}
          </h2>
          <div class="card !bg-blue-50/30 !border-blue-200/50">
            <p class="text-slate-700 leading-relaxed">{t(star.howToUse, locale)}</p>
          </div>
        </section>

        <!-- Who is it for -->
        <section>
          <h2 class="text-lg font-bold mb-3">
            {locale === "fr" ? "Pour qui ?" : "Who is it for?"}
          </h2>
          <p class="text-slate-600 leading-relaxed">{t(star.whoIsItFor, locale)}</p>
        </section>

        <!-- What to expect -->
        <section>
          <h2 class="text-lg font-bold mb-3">
            {locale === "fr" ? "A quoi s'attendre" : "What to expect"}
          </h2>
          <div class="card !bg-amber-50/30 !border-amber-200/50">
            <p class="text-slate-700 leading-relaxed">{t(star.whatToExpect, locale)}</p>
          </div>
        </section>

        <!-- Common mistakes -->
        <section>
          <h2 class="text-lg font-bold mb-3">
            {locale === "fr" ? "Erreurs a eviter" : "Common mistakes"}
          </h2>
          <div class="card !bg-red-50/30 !border-red-200/50">
            <p class="text-slate-700 leading-relaxed whitespace-pre-line">{t(star.commonMistakes, locale)}</p>
          </div>
        </section>

        <!-- FAQ -->
        {star.faq.length > 0 && (
          <section>
            <h2 class="text-lg font-bold mb-4">FAQ</h2>
            <div class="space-y-3">
              {star.faq.map((item, i) => (
                <details class="card !p-0 overflow-hidden" open={i === 0}>
                  <summary class="flex items-center justify-between p-4 cursor-pointer font-bold text-sm text-slate-800 hover:text-violet-700">
                    <span class="pr-4">{t(item.question, locale)}</span>
                    <svg class="w-5 h-5 shrink-0 text-slate-400 group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9" /></svg>
                  </summary>
                  <div class="px-4 pb-4 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
                    {t(item.answer, locale)}
                  </div>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- Vs Competitors -->
        {star.vsCompetitors.length > 0 && (
          <section>
            <h2 class="text-lg font-bold mb-4">
              {locale === "fr" ? "Comparaisons" : "How it compares"}
            </h2>
            <div class="space-y-4">
              {star.vsCompetitors.map((comp) => (
                <div class="card">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-sm font-bold text-slate-800">{product.brand} {product.name}</span>
                    <span class="text-violet-300 font-extrabold">vs</span>
                    <a href={localizedPath(`/product/${comp.competitorId}`, locale)} class="text-sm font-bold text-violet-600 hover:text-violet-700">
                      {comp.competitorName}
                    </a>
                  </div>
                  <p class="text-sm text-slate-600 leading-relaxed">{t(comp.verdict, locale)}</p>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    )}

    <!-- Alternatives -->
    {alternatives.length > 0 && (
      <section>
        <h2 class="text-xl font-bold mb-4">{t(tr.product.alternatives, locale)}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {alternatives.map((alt) => (
            <a href={localizedPath(`/product/${alt.id}`, locale)} class="card card-glow flex items-center gap-4">
              <div class={`grade grade-md ${gradeClass(alt.score)} shrink-0`}>{alt.score}</div>
              <div class="min-w-0">
                <p class="text-xs text-violet-600 font-semibold">{alt.brand}</p>
                <p class="text-sm font-bold text-slate-800 truncate">{alt.name}</p>
                <p class="text-xs text-slate-500">{alt.scoreNumeric}/100 - {alt.type}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
