---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { authors, type Author } from "../../data/authors";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";
import { getLocale, t, localizedPath } from "../../i18n/t";

export function getStaticPaths() {
  return authors.map((a) => ({
    params: { slug: a.id },
    props: { author: a },
  }));
}

const { author } = Astro.props as { author: Author };
const locale = getLocale(Astro.url);

const breadcrumbs = [
  { name: locale === "fr" ? "Accueil" : "Home", url: fullUrl(localizedPath("/", locale)) },
  { name: locale === "fr" ? "Equipe" : "Team", url: fullUrl(localizedPath("/about", locale)) },
  { name: author.name, url: fullUrl(localizedPath(`/authors/${author.id}`, locale)) },
];

const jsonLd = [
  jsonLdBreadcrumbs(breadcrumbs),
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: author.name,
    jobTitle: t(author.role, locale),
    description: t(author.bio, locale),
    url: fullUrl(`/authors/${author.id}`),
    worksFor: { "@id": `${siteConfig.url}/#organization` },
  },
];
---

<BaseLayout
  title={`${author.name} - ${t(author.role, locale)} | ${siteConfig.name}`}
  description={t(author.bio, locale)}
  jsonLd={jsonLd}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-xs text-slate-400 mb-8 flex items-center gap-1.5">
      {breadcrumbs.map((item, i) => (
        <>{i > 0 && <span>/</span>}{i < breadcrumbs.length - 1 ? <a href={item.url} class="hover:text-violet-600">{item.name}</a> : <span class="text-slate-600">{item.name}</span>}</>
      ))}
    </nav>

    <div class="flex items-start gap-6 mb-8">
      <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-100 to-indigo-100 flex items-center justify-center text-2xl font-extrabold text-violet-600 shrink-0">
        {author.name.split(" ").map((w) => w[0]).join("")}
      </div>
      <div>
        <h1 class="text-2xl font-extrabold mb-1">{author.name}</h1>
        <p class="text-violet-600 font-semibold mb-3">{t(author.role, locale)}</p>
        <p class="text-slate-600 leading-relaxed">{t(author.bio, locale)}</p>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-base font-bold mb-3">{locale === "fr" ? "Expertise" : "Areas of expertise"}</h2>
      <div class="flex flex-wrap gap-2">
        {author.expertise.map((e) => (
          <span class="text-sm px-3 py-1 rounded-full bg-violet-50 text-violet-600 font-medium">{e}</span>
        ))}
      </div>
    </div>

    <div class="border-t border-slate-200 pt-8">
      <p class="text-sm text-slate-500 leading-relaxed">
        {locale === "fr"
          ? `${author.name} fait partie de l'equipe editoriale de ${siteConfig.name}. Tous les scores et analyses sont revus par au moins deux membres de l'equipe avant publication. Notre methodologie est entierement transparente et basee sur les donnees EU CosIng, les avis SCCS et la recherche dermatologique revue par les pairs.`
          : `${author.name} is part of the ${siteConfig.name} editorial team. All scores and analyses are reviewed by at least two team members before publication. Our methodology is fully transparent and based on EU CosIng data, SCCS opinions, and peer-reviewed dermatological research.`}
      </p>
      <a href={localizedPath("/methodology", locale)} class="inline-block mt-3 text-sm text-violet-600 font-medium hover:text-violet-700">
        {locale === "fr" ? "Voir notre methodologie" : "See our methodology"} &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
