---
import { siteConfig } from "../../site.config";
import { getLocale, t, tr, localizedPath } from "../i18n/t";

const locale = getLocale(Astro.url);
const otherLocale = locale === "en" ? "fr" : "en";
const otherLabel = locale === "en" ? "FR" : "EN";
const otherPath = locale === "en"
  ? `/fr${Astro.url.pathname === "/" ? "/" : Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/fr/, "") || "/";
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3">
    <div class="flex items-center justify-between rounded-2xl bg-white/80 backdrop-blur-xl border border-slate-200/60 shadow-sm px-5 py-2.5">
      <!-- Logo -->
      <a href={localizedPath("/", locale)} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-600 to-indigo-600 flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3" />
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" />
          </svg>
        </div>
        <span class="text-lg font-extrabold tracking-tight">
          <span class="text-gradient">Skin</span><span class="text-slate-800">Score</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {siteConfig.navLinks.map((link) => (
          <a
            href={localizedPath(link.href, locale)}
            class="px-3 py-1.5 text-sm font-medium text-slate-600 hover:text-violet-700 rounded-lg hover:bg-violet-50 transition-colors"
          >
            {t({ en: link.label, fr: link.label === "Home" ? "Accueil" : link.label === "Rankings" ? "Classement" : link.label === "Compare" ? "Comparer" : link.label === "Ingredients" ? "Ingredients" : link.label === "Methodology" ? "Methodologie" : link.label }, locale)}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Lang switcher -->
        <a
          href={otherPath}
          class="text-xs font-bold px-2.5 py-1 rounded-full border border-slate-200 text-slate-500 hover:border-violet-300 hover:text-violet-600 transition-colors"
        >
          {otherLabel}
        </a>

        <!-- CTA -->
        <a
          href={localizedPath("/rankings", locale)}
          class="hidden sm:inline-flex btn-primary text-sm !px-4 !py-2"
        >
          {t(tr.nav.getScore, locale)}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors"
          aria-label="Menu"
        >
          <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden mx-4 mt-1">
    <div class="rounded-2xl bg-white/95 backdrop-blur-xl border border-slate-200/60 shadow-lg p-4 space-y-1">
      {siteConfig.navLinks.map((link) => (
        <a
          href={localizedPath(link.href, locale)}
          class="block px-4 py-2.5 text-sm font-medium text-slate-700 hover:text-violet-700 hover:bg-violet-50 rounded-xl transition-colors"
        >
          {t({ en: link.label, fr: link.label === "Home" ? "Accueil" : link.label === "Rankings" ? "Classement" : link.label === "Compare" ? "Comparer" : link.label === "Ingredients" ? "Ingredients" : link.label === "Methodology" ? "Methodologie" : link.label }, locale)}
        </a>
      ))}
      <a
        href={localizedPath("/rankings", locale)}
        class="block text-center btn-primary text-sm mt-2"
      >
        {t(tr.nav.getScore, locale)}
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script is:inline>
  // Mobile menu toggle
  (function () {
    var btn = document.getElementById("mobile-menu-btn");
    var menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;
    btn.addEventListener("click", function () {
      menu.classList.toggle("hidden");
    });
  })();

  // Header scroll effect
  (function () {
    var header = document.getElementById("site-header");
    if (!header) return;
    var lastY = 0;
    window.addEventListener("scroll", function () {
      var y = window.scrollY;
      if (y > 80 && y > lastY) {
        header.style.transform = "translateY(-100%)";
      } else {
        header.style.transform = "translateY(0)";
      }
      lastY = y;
    }, { passive: true });
  })();
</script>
