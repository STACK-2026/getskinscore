---
// GA4 tracker runs ALONGSIDE existing /tracker.js (Supabase, Mix mode).
// Same consent gate: respects `skinscore_cookie_consent` localStorage = "declined".
const GA4_ID = "G-11L24S36B5";
---

<script define:vars={{ GA4_ID }}>
  (function () {
    try {
      const v = localStorage.getItem("skinscore_cookie_consent");
      if (v === "declined") return;
    } catch (e) {}

    const s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA4_ID;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", GA4_ID);
  })();
</script>
