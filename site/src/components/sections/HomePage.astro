<style>
  /* Rotating text - width auto-calculated by JS */
  .si-rotating-container {
    display: inline-block;
    position: relative;
    height: 1.2em;
    vertical-align: bottom;
    overflow: hidden;
    transition: width 0.3s ease;
  }
  .si-rotating-word {
    position: absolute;
    left: 0;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.4s ease, transform 0.4s ease;
    white-space: nowrap;
  }
  .si-rotating-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Rotating badge */
  .si-badge-rotating {
    position: relative;
    display: inline-block;
    height: 1.3em;
    overflow: hidden;
    vertical-align: middle;
  }
  .si-badge-text {
    position: absolute;
    left: 0;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.4s ease, transform 0.4s ease;
    white-space: nowrap;
  }
  .si-badge-active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 640px) {
    .si-badge-text { white-space: normal; font-size: 0.75rem; }
    .si-badge-rotating { height: auto; min-height: 1.3em; }
  }

  /* Step circle with pulse */
  .si-step-circle {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #7C3AED, #4F46E5);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px -4px rgba(124, 58, 237, 0.5);
    position: relative;
  }
  .si-step-circle::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    border: 2px solid rgba(124, 58, 237, 0.3);
    animation: stepPulse 2s ease-in-out infinite;
  }
  @keyframes stepPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  /* Carousel */
  .si-carousel {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .si-carousel::-webkit-scrollbar { display: none; }
  .si-carousel-track {
    display: flex;
    gap: 1rem;
    padding-bottom: 0.5rem;
  }
  .si-carousel-item {
    scroll-snap-align: start;
  }
</style>

<!-- Animated counters + rotating text script -->
<script is:inline>
  // Animated counters
  (function () {
    var counters = document.querySelectorAll(".si-counter");
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.getAttribute("data-target"), 10);
        var duration = 1500;
        var start = performance.now();
        function update(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(target * eased).toLocaleString() + (target > 100 ? "+" : "");
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });
    counters.forEach(function (c) { observer.observe(c); });
  })();

  // Rotating hero text with auto-width
  (function () {
    var words = document.querySelectorAll(".si-rotating-word");
    var container = document.querySelector(".si-rotating-container");
    if (words.length < 2 || !container) return;
    var current = 0;

    function updateWidth() {
      var active = words[current];
      // Temporarily make visible to measure
      active.style.position = "relative";
      container.style.width = active.offsetWidth + "px";
      active.style.position = "";
    }

    // Set initial width
    updateWidth();

    setInterval(function () {
      words[current].classList.remove("si-rotating-active");
      current = (current + 1) % words.length;
      words[current].classList.add("si-rotating-active");
      updateWidth();
    }, 2000);
  })();

  // Rotating badge
  (function () {
    var badges = document.querySelectorAll(".si-badge-text");
    if (badges.length < 2) return;
    var current = 0;
    setInterval(function () {
      badges[current].classList.remove("si-badge-active");
      badges[current].style.position = "absolute";
      current = (current + 1) % badges.length;
      badges[current].classList.add("si-badge-active");
      badges[current].style.position = "relative";
    }, 4000);
  })();
</script>
