---
import { siteConfig } from "../../../site.config";
import { getLocale, t, tr, localizedPath } from "../../i18n/t";
import { ingredients } from "../../data/ingredients";
import { products, getUniqueBrands, brandSlug } from "../../data/products";

const locale = getLocale(Astro.url);

// Top products for showcase
const topProducts = [...products]
  .filter((p) => p.scoreNumeric >= 85)
  .sort((a, b) => b.scoreNumeric - a.scoreNumeric)
  .slice(0, 8);

// Worst famous products (editorial power)
const exposedProducts = products.filter((p) =>
  ["la-mer-creme-de-la-mer", "nivea-creme", "sol-de-janeiro-brazilian-bum-bum-cream", "garnier-skinactive-micellar-cleansing-water-all-in-1"].includes(p.id)
).sort((a, b) => a.scoreNumeric - b.scoreNumeric);

// Spotlight ingredients
const spotlightIngredients = ingredients.filter((i) =>
  ["retinol", "niacinamide", "hyaluronic-acid", "ascorbic-acid", "salicylic-acid", "centella-asiatica", "ceramide-np", "azelaic-acid"].includes(i.id)
);

// Top brands
const topBrandNames = ["CeraVe", "The Ordinary", "La Roche-Posay", "Paula's Choice", "Bioderma", "COSRX", "Drunk Elephant", "Avene", "SVR", "Vichy", "Eucerin", "Neutrogena", "Clinique", "Estee Lauder", "Lancome", "Shiseido", "SK-II", "La Mer", "Chanel", "Dior", "Tatcha", "Rhode", "Hada Labo", "Nuxe"];

// Rotating words for hero
const rotatingWords = locale === "fr"
  ? ["ton serum", "ta creme", "ton SPF", "ton nettoyant", "ton fond de teint", "ton contour des yeux"]
  : ["your serum", "your cream", "your SPF", "your cleanser", "your moisturiser", "your eye cream"];

// Grade helper
function gc(grade: string) { return `grade-${grade.toLowerCase()}`; }
---

<!-- ========== 1. HERO ========== -->
<section class="relative overflow-hidden pt-12 pb-20 md:pt-20 md:pb-28">
  <!-- Animated background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-violet-50 via-white to-indigo-50/40"></div>
    <div class="absolute top-20 left-[10%] w-72 h-72 bg-violet-200/15 rounded-full blur-[80px] molecule-float"></div>
    <div class="absolute bottom-10 right-[10%] w-80 h-80 bg-indigo-200/15 rounded-full blur-[80px] molecule-float" style="animation-delay:2s"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-amber-100/10 rounded-full blur-[100px] molecule-float" style="animation-delay:4s"></div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center relative">
    <!-- Badge -->
    <div class="reveal mb-6">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-50 text-red-700 text-sm font-semibold border border-red-200/50">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
        {locale === "fr" ? "67% des soins contiennent un ingredient douteux" : "67% of skincare products contain a concerning ingredient"}
      </div>
    </div>

    <!-- H1 with rotating word -->
    <h1 class="reveal mb-6 leading-[1.1]">
      <span class="block text-slate-800">
        {locale === "fr" ? "Est-ce que " : "Is "}
        <span class="si-rotating-container">
          {rotatingWords.map((word, i) => (
            <span class={`si-rotating-word ${i === 0 ? "si-rotating-active" : ""}`} data-index={i}>
              <span class="text-gradient">{word}</span>
            </span>
          ))}
        </span>
      </span>
      <span class="block text-slate-800">
        {locale === "fr" ? "te ment ?" : "lying to you?"}
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal text-lg md:text-xl text-slate-500 max-w-2xl mx-auto mb-10 leading-relaxed">
      {t(tr.hero.subtitle, locale)}
    </p>

    <!-- Search bar (prominent) -->
    <div class="reveal max-w-2xl mx-auto mb-12">
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-violet-400 to-indigo-400 rounded-2xl blur-lg opacity-0 group-hover:opacity-20 transition-opacity duration-500"></div>
        <div class="relative flex items-center bg-white rounded-xl border-2 border-slate-200 hover:border-violet-300 focus-within:border-violet-500 focus-within:ring-4 focus-within:ring-violet-100 transition-all duration-300 shadow-lg shadow-slate-200/50">
          <div class="pl-5 text-slate-400">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" stroke-linecap="round" /></svg>
          </div>
          <input type="text" placeholder={t(tr.hero.searchPlaceholder, locale)} class="flex-1 py-4 px-4 text-base bg-transparent outline-none placeholder:text-slate-400" disabled />
          <a href={localizedPath("/rankings", locale)} class="si-cta-btn mr-2 !rounded-lg !px-6 !py-3">
            {t(tr.hero.cta, locale)}
          </a>
        </div>
      </div>
    </div>

    <!-- Live score demo (3 products) -->
    <div class="reveal flex items-center justify-center gap-8 md:gap-12">
      <a href={localizedPath("/product/cerave-moisturizing-cream", locale)} class="group flex flex-col items-center">
        <div class="grade grade-xl grade-a grade-pulse shadow-lg group-hover:scale-110 transition-transform">A</div>
        <span class="text-xs text-slate-500 mt-2 font-semibold group-hover:text-violet-600 transition-colors">CeraVe</span>
        <span class="text-[10px] text-slate-400">88/100</span>
      </a>
      <a href={localizedPath("/product/rhode-peptide-glazing-fluid", locale)} class="group flex flex-col items-center">
        <div class="grade grade-xl grade-a shadow-lg group-hover:scale-110 transition-transform">A</div>
        <span class="text-xs text-slate-500 mt-2 font-semibold group-hover:text-violet-600 transition-colors">Rhode</span>
        <span class="text-[10px] text-slate-400">86/100</span>
      </a>
      <a href={localizedPath("/product/la-mer-creme-de-la-mer", locale)} class="group flex flex-col items-center">
        <div class="grade grade-xl grade-c shadow-lg group-hover:scale-110 transition-transform">C</div>
        <span class="text-xs text-slate-500 mt-2 font-semibold group-hover:text-violet-600 transition-colors">La Mer</span>
        <span class="text-[10px] text-slate-400">67/100</span>
      </a>
      <a href={localizedPath("/product/nivea-creme", locale)} class="group flex flex-col items-center opacity-60 hover:opacity-100 transition-opacity">
        <div class="grade grade-xl grade-c shadow-lg group-hover:scale-110 transition-transform">C</div>
        <span class="text-xs text-slate-500 mt-2 font-semibold group-hover:text-violet-600 transition-colors">Nivea</span>
        <span class="text-[10px] text-slate-400">58/100</span>
      </a>
    </div>

    <p class="text-[11px] text-slate-400 mt-4">
      {locale === "fr" ? "La Mer a 350EUR obtient le meme score que Nivea a 5EUR. La science ne ment pas." : "La Mer at 350EUR scores the same as Nivea at 5EUR. Science doesn't lie."}
    </p>
  </div>
</section>

<!-- ========== 2. MANIFESTE ========== -->
<section class="section bg-slate-900 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,58,237,0.15),transparent_70%)]"></div>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center relative">
    <h2 class="reveal text-2xl md:text-3xl font-extrabold mb-6 leading-tight">
      {locale === "fr"
        ? "On ne te vend rien. On te montre ce qu'on te vend."
        : "We don't sell you anything. We show you what they're selling you."}
    </h2>
    <p class="reveal text-lg text-white/60 leading-relaxed mb-8">
      {locale === "fr"
        ? "SkinScore est ne d'une frustration simple : pourquoi est-ce si difficile de savoir ce qu'il y a dans un soin ? Pourquoi faut-il un diplome en chimie pour lire une etiquette ? Pourquoi les marques depensent plus en marketing qu'en formulation ? On a decide de changer ca. Chaque ingredient, passe au crible. Chaque produit, note sans concession. Aucune marque ne nous paie. Aucune ne peut acheter un meilleur score."
        : "SkinScore was born from a simple frustration: why is it so hard to know what's in your skincare? Why do you need a chemistry degree to read a label? Why do brands spend more on marketing than formulation? We decided to change that. Every ingredient, dissected. Every product, scored without compromise. No brand pays us. None can buy a better score."}
    </p>
    <div class="reveal flex flex-wrap justify-center gap-4 text-sm">
      <span class="px-4 py-2 rounded-full bg-white/10 border border-white/10">{locale === "fr" ? "Zero partenariat marque" : "Zero brand deals"}</span>
      <span class="px-4 py-2 rounded-full bg-white/10 border border-white/10">{locale === "fr" ? "Donne UE CosIng + SCCS" : "EU CosIng + SCCS data"}</span>
      <span class="px-4 py-2 rounded-full bg-white/10 border border-white/10">{locale === "fr" ? "Methodologie 100% transparente" : "100% transparent methodology"}</span>
    </div>
  </div>
</section>

<!-- ========== 3. STATS (animated counters) ========== -->
<section class="section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="reveal-children grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center p-6 rounded-2xl bg-gradient-to-br from-violet-50 to-white border border-violet-100/50">
        <p class="text-4xl md:text-5xl font-extrabold text-gradient si-counter" data-target="2680">0</p>
        <p class="text-sm text-slate-500 mt-2 font-medium">{t(tr.stats.products, locale)}</p>
      </div>
      <div class="text-center p-6 rounded-2xl bg-gradient-to-br from-indigo-50 to-white border border-indigo-100/50">
        <p class="text-4xl md:text-5xl font-extrabold text-gradient si-counter" data-target="101">0</p>
        <p class="text-sm text-slate-500 mt-2 font-medium">{t(tr.stats.ingredients, locale)}</p>
      </div>
      <div class="text-center p-6 rounded-2xl bg-gradient-to-br from-amber-50 to-white border border-amber-100/50">
        <p class="text-4xl md:text-5xl font-extrabold text-gradient si-counter" data-target="250">0</p>
        <p class="text-sm text-slate-500 mt-2 font-medium">{t(tr.stats.brands, locale)}</p>
      </div>
      <div class="text-center p-6 rounded-2xl bg-gradient-to-br from-emerald-50 to-white border border-emerald-100/50">
        <p class="text-4xl md:text-5xl font-extrabold text-gradient si-counter" data-target="5">0</p>
        <p class="text-sm text-slate-500 mt-2 font-medium">{locale === "fr" ? "Dimensions d'analyse" : "Scoring dimensions"}</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== 4. PROBLEM (3 threat cards) ========== -->
<section class="section section-alt">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-4">{t(tr.problem.title, locale)}</h2>
    <p class="reveal text-center text-slate-500 max-w-2xl mx-auto mb-10">{t(tr.problem.text, locale)}</p>

    <div class="reveal-children grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card card-glow !border-red-200/50 !bg-red-50/20 p-6">
        <div class="w-12 h-12 rounded-2xl bg-red-100 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-red-900">{locale === "fr" ? "Parfum = allergene n1" : "Fragrance = #1 allergen"}</h3>
        <p class="text-sm text-red-800/70 leading-relaxed">{locale === "fr" ? "L'UE liste 26 allergenes du parfum. Pourtant, 'Parfum' cache des centaines de molecules non divulguees. Le top allergene en dermatologie." : "The EU lists 26 fragrance allergens. Yet 'Parfum' hides hundreds of undisclosed chemicals. The top allergen in dermatology."}</p>
      </div>
      <div class="card card-glow !border-amber-200/50 !bg-amber-50/20 p-6">
        <div class="w-12 h-12 rounded-2xl bg-amber-100 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-amber-900">{locale === "fr" ? "Perturbateurs endocriniens" : "Endocrine disruptors"}</h3>
        <p class="text-sm text-amber-800/70 leading-relaxed">{locale === "fr" ? "Oxybenzone, octinoxate, certains parabenes. Des molecules qui miment tes hormones. Interdites a Hawaii pour les recifs, mais legales dans ton soin." : "Oxybenzone, octinoxate, certain parabens. Molecules that mimic your hormones. Banned in Hawaii for coral reefs, but legal in your skincare."}</p>
      </div>
      <div class="card card-glow !border-violet-200/50 !bg-violet-50/20 p-6 !border-2">
        <div class="w-12 h-12 rounded-2xl bg-violet-100 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-violet-900">{locale === "fr" ? "SkinScore lit pour toi" : "SkinScore reads for you"}</h3>
        <p class="text-sm text-violet-800/70 leading-relaxed">{locale === "fr" ? "On decode chaque nom INCI, on croise avec les bases UE CosIng et SCCS, et on te donne un score honnete de A a E. En 2 secondes." : "We decode every INCI name, cross-reference with EU CosIng and SCCS databases, and give you an honest A-to-E score. In 2 seconds."}</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== 5. FEATURES ========== -->
<section class="section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-10">{t(tr.features.title, locale)}</h2>
    <div class="reveal-children grid grid-cols-1 md:grid-cols-3 gap-6">
      {siteConfig.features.map((feature) => (
        <div class="card card-glow text-center p-8">
          <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-violet-100 flex items-center justify-center">
            {feature.icon === "zap" && <svg class="w-7 h-7 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>}
            {feature.icon === "shield" && <svg class="w-7 h-7 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>}
            {feature.icon === "user" && <svg class="w-7 h-7 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>}
          </div>
          <h3 class="text-lg font-bold mb-2">{feature.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ========== 6. HOW IT WORKS ========== -->
<section class="section section-alt">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-12">{t(tr.howItWorks.title, locale)}</h2>
    <div class="reveal-children grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { num: "1", title: t(tr.howItWorks.step1, locale), desc: t(tr.howItWorks.step1desc, locale) },
        { num: "2", title: t(tr.howItWorks.step2, locale), desc: t(tr.howItWorks.step2desc, locale) },
        { num: "3", title: t(tr.howItWorks.step3, locale), desc: t(tr.howItWorks.step3desc, locale) },
      ].map((step) => (
        <div class="text-center">
          <div class="si-step-circle mx-auto mb-4">
            <span class="text-xl font-extrabold text-white">{step.num}</span>
          </div>
          <h3 class="text-base font-bold mb-2">{step.title}</h3>
          <p class="text-sm text-slate-600">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ========== 7. TOP RATED CAROUSEL ========== -->
<section class="section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="reveal">{locale === "fr" ? "Les mieux notes" : "Top rated"}</h2>
      <a href={localizedPath("/rankings", locale)} class="text-sm font-medium text-violet-600 hover:text-violet-700">
        {t(tr.common.viewAll, locale)} &rarr;
      </a>
    </div>
    <div class="si-carousel reveal">
      <div class="si-carousel-track">
        {topProducts.map((p) => (
          <a href={localizedPath(`/product/${p.id}`, locale)} class="si-carousel-item card card-glow !p-4 shrink-0 w-64">
            {p.image && <img src={p.image} alt={`${p.brand} ${p.name}`} class="w-full h-32 object-contain rounded-lg bg-slate-50 mb-3" loading="lazy" />}
            <div class="flex items-center gap-2 mb-2">
              <div class={`grade grade-sm ${gc(p.score)}`}>{p.score}</div>
              <span class="text-xs text-violet-600 font-semibold">{p.brand}</span>
            </div>
            <p class="text-sm font-bold text-slate-800 truncate">{p.name}</p>
            <p class="text-xs text-slate-400">{p.scoreNumeric}/100</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ========== 8. EXPOSED ("soins qui mentent") ========== -->
{exposedProducts.length > 0 && (
  <section class="section section-warm">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="reveal text-center mb-3">{locale === "fr" ? "Les soins qui vous mentent" : "Products that lie to you"}</h2>
      <p class="reveal text-center text-slate-500 mb-10 max-w-2xl mx-auto">
        {locale === "fr"
          ? "Des prix premium, des ingredients mediocres. La preuve que cher ne veut pas dire meilleur."
          : "Premium prices, mediocre ingredients. Proof that expensive doesn't mean better."}
      </p>
      <div class="reveal-children grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {exposedProducts.map((p) => (
          <a href={localizedPath(`/product/${p.id}`, locale)} class="card card-glow !border-red-200/30 hover:!border-red-300 !p-4 group">
            <div class="flex items-center gap-2 mb-2">
              <div class={`grade grade-md ${gc(p.score)}`}>{p.score}</div>
              <div>
                <p class="text-xs text-red-600 font-semibold">{p.brand}</p>
                <p class="text-sm font-bold text-slate-800 group-hover:text-red-700 transition-colors truncate">{p.name}</p>
              </div>
            </div>
            <p class="text-xs text-slate-500">{p.scoreNumeric}/100 {p.price ? `- ${p.price}EUR` : ""}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ========== 9. SKIN CONCERNS ========== -->
<section class="section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-10">{t(tr.concerns.title, locale)}</h2>
    <div class="reveal-children grid grid-cols-2 sm:grid-cols-4 gap-4">
      {siteConfig.concerns.map((concern) => (
        <a href={localizedPath(`/best/${concern.id}`, locale)} class="card card-glow text-center p-5 group">
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-violet-100 group-hover:bg-violet-200 flex items-center justify-center transition-all duration-300 group-hover:scale-110">
            <span class="text-xl">{concern.icon === "droplets" ? "💧" : concern.icon === "clock" ? "⏳" : concern.icon === "sun" ? "☀️" : concern.icon === "flame" ? "🔥" : concern.icon === "wind" ? "💨" : concern.icon === "heart" ? "💜" : concern.icon === "droplet" ? "💦" : "⭕"}</span>
          </div>
          <span class="text-sm font-bold text-slate-800 group-hover:text-violet-700 transition-colors">{t(concern.label, locale)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ========== 10. INGREDIENTS SPOTLIGHT ========== -->
<section class="section section-alt">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="reveal">{t(tr.ingredientsSection.title, locale)}</h2>
      <a href={localizedPath("/encyclopedia", locale)} class="text-sm font-medium text-violet-600 hover:text-violet-700">
        {t(tr.ingredientsSection.viewAll, locale)} &rarr;
      </a>
    </div>
    <div class="si-carousel reveal">
      <div class="si-carousel-track">
        {spotlightIngredients.map((ing) => (
          <a href={localizedPath(`/ingredient/${ing.id}`, locale)} class="si-carousel-item card card-glow ingredient-glow flex items-start gap-3 !p-5 shrink-0 w-72">
            <div class={`grade grade-md ${gc(ing.score)} shrink-0 mt-0.5`}>{ing.score}</div>
            <div class="min-w-0">
              <h3 class="text-sm font-bold text-slate-800 mb-1">{t(ing.name, locale)}</h3>
              <p class="text-xs text-slate-500 leading-relaxed line-clamp-3">{t(ing.description, locale).slice(0, 120)}...</p>
              <div class="flex flex-wrap gap-1 mt-2">
                {ing.concerns.slice(0, 3).map((c) => (
                  <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-violet-50 text-violet-600">{c}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ========== 11. COMING SOON: Interaction Checker + Dupe Finder ========== -->
<section class="section bg-slate-900 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(124,58,237,0.2),transparent_70%)]"></div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-500/20 text-violet-300 text-sm font-semibold mb-4 border border-violet-500/20">
        <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
        {locale === "fr" ? "Bientot disponible" : "Coming soon"}
      </div>
      <h2 class="reveal text-2xl md:text-3xl font-extrabold mb-4">
