<!-- ========== STYLES ========== -->
<style>
  /* Gradient animated background */
  .gradient-animated {
    background-size: 300% 300%;
    animation: gradientShift 8s ease infinite;
  }
  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Step circle with pulse */
  .si-step-circle {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, #7C3AED, #4F46E5);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset, 0 4px 14px -4px rgba(124, 58, 237, 0.5);
    position: relative;
  }
  .si-step-circle::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 9999px;
    border: 2px solid rgba(124, 58, 237, 0.3);
    animation: stepPulse 2s ease-in-out infinite;
  }
  @keyframes stepPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.15); opacity: 0; }
  }

  /* Carousel */
  .si-carousel {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .si-carousel::-webkit-scrollbar { display: none; }
  .si-carousel-track {
    display: flex;
    gap: 1rem;
    padding-bottom: 0.5rem;
  }
  .si-carousel-item {
    scroll-snap-align: start;
  }

  /* Score card - hover-shine + hover-tilt */
  .si-score-card {
    will-change: transform;
    position: relative;
    overflow: hidden;
  }
  .si-score-card::after {
    content: "";
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: linear-gradient(to bottom right, transparent 40%, rgba(255,255,255,0.06) 50%, transparent 60%);
    transform: rotate(30deg) translateX(-100%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .si-score-card:hover::after {
    transform: rotate(30deg) translateX(100%);
  }
  .si-score-card:hover {
    transform: perspective(800px) rotateX(-1deg) rotateY(1deg) translateY(-4px);
  }

  /* Grade text colors */
  .grade-a-text { color: #10b981; }
  .grade-b-text { color: #3b82f6; }
  .grade-c-text { color: #f59e0b; }
  .grade-d-text { color: #f97316; }
  .grade-e-text { color: #ef4444; }

  /* Quiz skin type cards float */
  .quiz-skin-card {
    animation: quizFloat 3s ease-in-out infinite;
  }
  .quiz-skin-card:nth-child(2) { animation-delay: 0.5s; }
  .quiz-skin-card:nth-child(3) { animation-delay: 1s; }
  .quiz-skin-card:nth-child(4) { animation-delay: 1.5s; }
  .quiz-skin-card:nth-child(5) { animation-delay: 2s; }
  .quiz-skin-card:nth-child(6) { animation-delay: 2.5s; }
  @keyframes quizFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .quiz-skin-card,
    .si-step-circle::after,
    .hero-orb,
    .gradient-animated {
      animation: none !important;
    }
    .si-score-card:hover { transform: none; }
    .si-score-card::after { display: none; }
  }

  @media (max-width: 640px) {
    .si-score-card::after { display: none; }
  }
</style>

<!-- ========== SCRIPTS ========== -->
<script is:inline>
  // Animated counters (ease-out-quart)
  (function () {
    var counters = document.querySelectorAll(".si-counter");
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.getAttribute("data-target"), 10);
        var duration = 1500;
        var start = performance.now();
        function update(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 4); // ease-out-quart
          el.textContent = Math.round(target * eased).toLocaleString() + (target > 100 ? "+" : "");
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });
    counters.forEach(function (c) { observer.observe(c); });
  })();

  // Animated score bars
  (function () {
    var bars = document.querySelectorAll(".si-score-bar");
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var width = el.getAttribute("data-width");
        setTimeout(function () { el.style.width = width + "%"; }, 100);
        observer.unobserve(el);
      });
    }, { threshold: 0.2 });
    bars.forEach(function (b) { observer.observe(b); });
  })();

  // Parallax hero orbs on scroll
  (function () {
    var orbs = document.querySelectorAll(".hero-orb");
    var parallaxEls = document.querySelectorAll("[data-parallax]");
    if (!orbs.length && !parallaxEls.length) return;
    var ticking = false;
    window.addEventListener("scroll", function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          var scrollY = window.scrollY;
          orbs.forEach(function (orb) {
            var speed = parseFloat(orb.getAttribute("data-speed") || "0.01");
            orb.style.transform = "translateY(" + (scrollY * speed * 100) + "px)";
          });
          parallaxEls.forEach(function (el) {
            var speed = parseFloat(el.getAttribute("data-parallax") || "0.05");
            el.style.transform = "translateY(" + (scrollY * speed * -20) + "px)";
          });
          ticking = false;
        });
        ticking = true;
      }
    });
  })();

  // Cursor glow (desktop only)
  (function () {
    if (!window.matchMedia("(pointer: fine)").matches) return;
    var glow = document.getElementById("cursor-glow");
    if (!glow) {
      glow = document.createElement("div");
      glow.id = "cursor-glow";
      document.body.appendChild(glow);
    }
    var x = 0, y = 0, cx = 0, cy = 0;
    document.addEventListener("mousemove", function (e) {
      x = e.clientX; y = e.clientY;
      glow.style.opacity = "1";
    });
    document.addEventListener("mouseleave", function () { glow.style.opacity = "0"; });
    function lerp() {
      cx += (x - cx) * 0.08;
      cy += (y - cy) * 0.08;
      glow.style.left = cx + "px";
      glow.style.top = cy + "px";
      requestAnimationFrame(lerp);
    }
    lerp();
  })();
</script>
