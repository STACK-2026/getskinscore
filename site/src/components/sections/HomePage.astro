---
import { siteConfig } from "../../../site.config";
import { getLocale, t, tr, localizedPath } from "../../i18n/t";
import { ingredients } from "../../data/ingredients";
import { products, getUniqueBrands, brandSlug } from "../../data/products";
import { getCollection } from "astro:content";
import TextMorph from "../TextMorph.astro";

const locale = getLocale(Astro.url);
const now = new Date();

// Top products for showcase (with images preferred)
const topProducts = [...products]
  .filter((p) => p.scoreNumeric >= 85)
  .sort((a, b) => (b.image ? 1 : 0) - (a.image ? 1 : 0) || b.scoreNumeric - a.scoreNumeric)
  .slice(0, 12);

// Worst famous products (editorial power)
const exposedProducts = products.filter((p) =>
  ["la-mer-creme-de-la-mer", "nivea-creme", "sol-de-janeiro-brazilian-bum-bum-cream", "garnier-skinactive-micellar-cleansing-water-all-in-1"].includes(p.id)
).sort((a, b) => a.scoreNumeric - b.scoreNumeric);

// Score preview product
const previewProduct = products.find((p) => p.id === "cerave-moisturizing-cream")!;
const comparisonProduct = products.find((p) => p.id === "la-mer-creme-de-la-mer")!;

// Spotlight ingredients
const spotlightIngredients = ingredients.filter((i) =>
  ["retinol", "niacinamide", "hyaluronic-acid", "ascorbic-acid", "salicylic-acid", "centella-asiatica", "ceramide-np", "azelaic-acid"].includes(i.id)
);

// Hero phrases for TextMorph (shorter for mobile compatibility)
const heroMorphPhrases = locale === "fr"
  ? ["ton serum te ment ?", "ta creme te ment ?", "ton SPF te ment ?", "ton nettoyant te ment ?", "ton contour des yeux te ment ?"]
  : ["your serum lying to you?", "your cream lying to you?", "your SPF lying to you?", "your cleanser lying to you?", "your eye cream lying to you?"];

// Badge rotating phrases
const badgePhrases = locale === "fr"
  ? ["67% des soins contiennent un ingredient douteux", "La Mer a 350 EUR obtient un C. Nivea a 5 EUR aussi.", "Le parfum est l'allergene n1 en cosmetique", "2 700+ soins notes de A a E. Aucune marque ne nous paie.", "Ton serum a 80 EUR a les memes actifs que celui a 12 EUR"]
  : ["67% of skincare products contain a concerning ingredient", "La Mer at 350 EUR scores a C. Nivea at 5 EUR also scores C.", "Fragrance is the #1 allergen in cosmetics", "2,700+ products scored A to E. No brand pays us.", "Your 80 EUR serum has the same actives as this 12 EUR one"];

// CTA morph phrases
const ctaMorphPhrases = locale === "fr"
  ? ["Verifier mon soin", "Analyser ma creme", "Decoder mes ingredients"]
  : ["Check my product", "Analyse my cream", "Decode my ingredients"];

// Blog posts
const blogLang = locale;
const blogPosts = (await getCollection("blog", ({ data }) =>
  !data.draft && data.lang === blogLang && data.date.valueOf() <= now.valueOf()
)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

// Grade helper
function gc(grade: string) { return `grade-${grade.toLowerCase()}`; }

// Sub-score numeric values (A=90, B=75, C=60, D=40, E=20)
function gradeToNum(g: string): number {
  return { A: 92, B: 75, C: 60, D: 40, E: 20 }[g] ?? 50;
}

const subScoreLabels = [
  { key: "efficacy", label: t(tr.product.efficacy, locale), icon: "⚡" },
  { key: "safety", label: t(tr.product.safety, locale), icon: "🛡" },
  { key: "comedogenicity", label: t(tr.product.comedogenicity, locale), icon: "🔬" },
  { key: "transparency", label: t(tr.product.transparency, locale), icon: "👁" },
  { key: "skinTypeFit", label: t(tr.product.skinTypeFit, locale), icon: "🎯" },
];
---

<!-- ========== 1. HERO ========== -->
<section class="relative overflow-hidden py-16 sm:py-24 md:py-36 px-4">
  <!-- Animated gradient background (very subtle) -->
  <div class="absolute inset-0 gradient-animated opacity-[0.03]" style="background: linear-gradient(135deg, #7C3AED, #4F46E5, #F59E0B, #7C3AED); background-size: 300% 300%;"></div>
  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-[0.02] hidden sm:block" style="background-image: linear-gradient(#7C3AED 1px, transparent 1px), linear-gradient(to right, #7C3AED 1px, transparent 1px); background-size: 60px 60px;"></div>
  <!-- Parallax orbs -->
  <div class="hero-orb absolute top-20 left-[10%] w-72 h-72 bg-violet-200/15 rounded-full blur-[80px]" data-speed="0.02"></div>
  <div class="hero-orb absolute bottom-10 right-[10%] w-80 h-80 bg-indigo-200/15 rounded-full blur-[80px]" data-speed="-0.015"></div>
  <!-- Floating grade badges (decorative) -->
  <div class="hidden md:block absolute top-[20%] left-[5%] grade grade-sm grade-a opacity-20 molecule-float" style="animation-delay:1s">A</div>
  <div class="hidden md:block absolute top-[60%] right-[8%] grade grade-sm grade-c opacity-15 molecule-float" style="animation-delay:3s">C</div>

  <div class="max-w-4xl mx-auto text-center relative">
    <!-- Badge urgence -->
    <div class="scale-reveal mb-6 sm:mb-10">
      <div class="inline-flex items-center gap-2 px-3 sm:px-4 py-1.5 rounded-full bg-red-50 text-red-700 text-xs sm:text-sm font-semibold border border-red-200/50">
        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
        <TextMorph
          phrases={badgePhrases}
          interval={4000}
          class="font-semibold"
        />
      </div>
    </div>

    <!-- H1 with TextMorph (FLIP morphing) -->
    <h1 class="mb-6 sm:mb-8 text-[1.75rem] sm:text-[2.5rem] md:text-[3.5rem] leading-[1.1]" data-split-words>
      <span class="block text-slate-800" data-split-words>
        {locale === "fr" ? "Est-ce que" : "Is"}
      </span>
      <span class="block mt-1 sm:mt-2 text-gradient">
        <TextMorph
          phrases={heroMorphPhrases}
          interval={2800}
          class="font-extrabold"
        />
      </span>
    </h1>

    <!-- Subtitle (blur reveal) -->
    <p class="reveal text-base sm:text-lg md:text-xl text-slate-500 max-w-2xl mx-auto mb-8 sm:mb-12 leading-relaxed px-2">
      {t(tr.hero.subtitle, locale)}
    </p>

    <!-- Search bar with inner glow CTA -->
    <div class="reveal max-w-2xl mx-auto mb-12">
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-violet-400 to-indigo-400 rounded-[2.5rem] blur-lg opacity-0 group-hover:opacity-15 transition-opacity duration-500"></div>
        <div class="relative bg-white rounded-full border-2 border-slate-200 hover:border-violet-300 focus-within:border-violet-500 focus-within:ring-4 focus-within:ring-violet-100 transition-all duration-300 shadow-lg shadow-slate-200/50">
          <div class="flex items-center">
            <div class="pl-5 text-slate-400 shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" stroke-linecap="round" /></svg>
            </div>
            <input type="text" placeholder={t(tr.hero.searchPlaceholder, locale)} class="flex-1 py-4 px-3 text-sm sm:text-base bg-transparent outline-none placeholder:text-slate-400 min-w-0" disabled />
            <a href={localizedPath("/rankings", locale)} class="si-cta-btn !px-6 !py-2.5 mr-1.5 text-sm hidden sm:inline-flex">
              <TextMorph
                phrases={ctaMorphPhrases}
                interval={3500}
                class="font-bold"
              />
            </a>
          </div>
          <div class="px-3 pb-3 sm:hidden">
            <a href={localizedPath("/rankings", locale)} class="si-cta-btn w-full justify-center !py-3 text-sm">
              {t(tr.hero.cta, locale)}
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Live score demo - staggered reveal -->
    <div class="reveal-children flex flex-wrap items-center justify-center gap-6 sm:gap-8 md:gap-12">
      {[
        { id: "cerave-moisturizing-cream", brand: "CeraVe", score: "A", num: 88, price: "15 EUR" },
        { id: "rhode-peptide-glazing-fluid", brand: "Rhode", score: "A", num: 86, price: "29 EUR" },
        { id: "la-mer-creme-de-la-mer", brand: "La Mer", score: "C", num: 67, price: "350 EUR" },
        { id: "nivea-creme", brand: "Nivea", score: "C", num: 58, price: "5 EUR" },
      ].map((p, i) => (
        <a href={localizedPath(`/product/${p.id}`, locale)} class={`group flex flex-col items-center ${i >= 2 ? "opacity-60 hover:opacity-100" : ""} transition-all duration-300`}>
          <div class={`grade grade-xl ${gc(p.score)} ${i === 0 ? "grade-pulse" : ""} shadow-lg group-hover:scale-110 transition-transform duration-300`}>{p.score}</div>
          <span class="text-xs text-slate-500 mt-2 font-semibold group-hover:text-violet-600 transition-colors">{p.brand}</span>
          <span class="text-[10px] text-slate-400">{p.num}/100 · {p.price}</span>
        </a>
      ))}
    </div>

    <p class="text-[11px] text-slate-400 mt-6" data-parallax="0.03">
      {locale === "fr" ? "La Mer a 350 EUR obtient le meme score que Nivea a 5 EUR. La science ne ment pas." : "La Mer at 350 EUR scores the same as Nivea at 5 EUR. Science doesn't lie."}
    </p>
  </div>
</section>

<!-- ========== 2. STATS (animated counters) ========== -->
<section class="py-8 md:py-10 border-y border-slate-100 bg-white/60 backdrop-blur-sm">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="reveal-children grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-extrabold text-gradient si-counter" data-target="2680">0</p>
        <p class="text-xs text-slate-500 mt-1 font-medium">{t(tr.stats.products, locale)}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-extrabold text-gradient si-counter" data-target="101">0</p>
        <p class="text-xs text-slate-500 mt-1 font-medium">{t(tr.stats.ingredients, locale)}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-extrabold text-gradient si-counter" data-target="250">0</p>
        <p class="text-xs text-slate-500 mt-1 font-medium">{t(tr.stats.brands, locale)}</p>
      </div>
      <div class="text-center">
        <p class="text-3xl md:text-4xl font-extrabold text-gradient si-counter" data-target="5">0</p>
        <p class="text-xs text-slate-500 mt-1 font-medium">{locale === "fr" ? "Dimensions d'analyse" : "Scoring dimensions"}</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== 3. MANIFESTE ========== -->
<section class="section bg-slate-900 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(124,58,237,0.2),transparent_70%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(79,70,229,0.1),transparent_60%)]"></div>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center relative">
    <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-violet-300 text-sm font-semibold mb-6">
      <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
      {locale === "fr" ? "Notre mission" : "Our mission"}
    </div>
    <h2 class="reveal text-2xl md:text-4xl font-extrabold mb-6 leading-tight text-white">
      {locale === "fr"
        ? "On ne te vend rien. On te montre ce qu'on te vend."
        : "We don't sell you anything. We show you what they're selling you."}
    </h2>
    <p class="reveal text-base md:text-lg text-white/50 leading-relaxed mb-8">
      {locale === "fr"
        ? "SkinScore est ne d'une frustration simple : pourquoi est-ce si difficile de savoir ce qu'il y a dans un soin ? Pourquoi faut-il un diplome en chimie pour lire une etiquette ? Pourquoi les marques depensent plus en marketing qu'en formulation ? On a decide de changer ca. Chaque ingredient, passe au crible. Chaque produit, note sans concession. Aucune marque ne nous paie. Aucune ne peut acheter un meilleur score."
        : "SkinScore was born from a simple frustration: why is it so hard to know what's in your skincare? Why do you need a chemistry degree to read a label? Why do brands spend more on marketing than formulation? We decided to change that. Every ingredient, dissected. Every product, scored without compromise. No brand pays us. None can buy a better score."}
    </p>
    <div class="reveal flex flex-wrap justify-center gap-3 text-sm">
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/70 hover:bg-white/10 transition-colors">{locale === "fr" ? "Zero partenariat marque" : "Zero brand deals"}</span>
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/70 hover:bg-white/10 transition-colors">{locale === "fr" ? "Donnees UE CosIng + SCCS" : "EU CosIng + SCCS data"}</span>
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/70 hover:bg-white/10 transition-colors">{locale === "fr" ? "Methodologie 100% transparente" : "100% transparent methodology"}</span>
    </div>
  </div>
</section>

<!-- ========== 4. PROBLEM (3 threat cards) ========== -->
<section class="section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-4">{t(tr.problem.title, locale)}</h2>
    <p class="reveal text-center text-slate-500 max-w-2xl mx-auto mb-10">{t(tr.problem.text, locale)}</p>

    <div class="reveal-children grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card card-glow !border-red-200/50 !bg-red-50/20 p-6 group hover:!border-red-300 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-red-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-red-900">{locale === "fr" ? "Parfum = allergene n1" : "Fragrance = #1 allergen"}</h3>
        <p class="text-sm text-red-800/70 leading-relaxed">{locale === "fr" ? "L'UE liste 26 allergenes du parfum. Pourtant, 'Parfum' cache des centaines de molecules non divulguees. Le top allergene en dermatologie." : "The EU lists 26 fragrance allergens. Yet 'Parfum' hides hundreds of undisclosed chemicals. The top allergen in dermatology."}</p>
      </div>
      <div class="card card-glow !border-amber-200/50 !bg-amber-50/20 p-6 group hover:!border-amber-300 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-amber-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-amber-900">{locale === "fr" ? "Perturbateurs endocriniens" : "Endocrine disruptors"}</h3>
        <p class="text-sm text-amber-800/70 leading-relaxed">{locale === "fr" ? "Oxybenzone, octinoxate, certains parabenes. Des molecules qui miment tes hormones. Interdites a Hawaii pour les recifs, mais legales dans ton soin." : "Oxybenzone, octinoxate, certain parabens. Molecules that mimic your hormones. Banned in Hawaii for coral reefs, but legal in your skincare."}</p>
      </div>
      <div class="card card-glow !border-violet-200/50 !bg-violet-50/20 p-6 !border-2 group hover:!border-violet-300 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-violet-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="text-base font-bold mb-2 text-violet-900">{locale === "fr" ? "SkinScore lit pour toi" : "SkinScore reads for you"}</h3>
        <p class="text-sm text-violet-800/70 leading-relaxed">{locale === "fr" ? "On decode chaque nom INCI, on croise avec les bases UE CosIng et SCCS, et on te donne un score honnete de A a E. En 2 secondes." : "We decode every INCI name, cross-reference with EU CosIng and SCCS databases, and give you an honest A-to-E score. In 2 seconds."}</p>
      </div>
    </div>
  </div>
</section>

<!-- ========== 5. SCORE PREVIEW (the "aha moment") ========== -->
<section class="section section-alt">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-100 text-violet-700 text-sm font-semibold mb-4">
        {locale === "fr" ? "Exemple en direct" : "Live example"}
      </div>
      <h2 class="reveal mb-3">{locale === "fr" ? "Ce que tu vois quand tu analyses un soin" : "What you see when you analyse a product"}</h2>
      <p class="reveal text-slate-500 max-w-xl mx-auto text-sm">
        {locale === "fr" ? "5 dimensions, un score final, zero bullshit." : "5 dimensions, one final score, zero BS."}
      </p>
    </div>

    <!-- Side-by-side comparison: CeraVe A vs La Mer C -->
    <div class="reveal-children grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- CeraVe - the winner -->
      <a href={localizedPath(`/product/${previewProduct.id}`, locale)} class="si-score-card group block p-6 rounded-2xl bg-white border-2 border-emerald-200/50 hover:border-emerald-300 shadow-sm hover:shadow-lg transition-all duration-300">
        <div class="flex items-center gap-4 mb-6">
          {previewProduct.image && <img src={previewProduct.image} alt={previewProduct.name} class="w-14 h-14 rounded-xl object-cover bg-slate-100" loading="lazy" />}
          <div class="flex-1 min-w-0">
            <p class="text-xs text-violet-600 font-semibold">{previewProduct.brand}</p>
            <p class="text-sm font-bold text-slate-800 truncate">{previewProduct.name}</p>
            <p class="text-xs text-slate-400">{previewProduct.price} EUR · {previewProduct.size}</p>
          </div>
          <div class={`grade grade-lg ${gc(previewProduct.score)} grade-pulse`}>{previewProduct.score}</div>
        </div>
        <div class="space-y-3">
          {subScoreLabels.map((s) => {
            const grade = (previewProduct.subScores as any)[s.key] as string;
            const num = gradeToNum(grade);
            return (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs text-slate-600 font-medium">{s.icon} {s.label}</span>
                  <span class={`text-xs font-bold ${gc(grade)}-text`}>{grade}</span>
                </div>
                <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                  <div class="si-score-bar h-full rounded-full transition-all duration-1000" data-width={num} style={`width: 0%; background: ${grade === "A" ? "#10b981" : grade === "B" ? "#3b82f6" : "#f59e0b"}`}></div>
                </div>
              </div>
            );
          })}
        </div>
        <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between">
          <span class="text-2xl font-extrabold text-gradient">{previewProduct.scoreNumeric}/100</span>
          <span class="text-xs text-slate-400 group-hover:text-violet-600 transition-colors">{locale === "fr" ? "Voir la fiche" : "View details"} &rarr;</span>
        </div>
      </a>

      <!-- La Mer - the exposed -->
      <a href={localizedPath(`/product/${comparisonProduct.id}`, locale)} class="si-score-card group block p-6 rounded-2xl bg-white border-2 border-red-200/50 hover:border-red-300 shadow-sm hover:shadow-lg transition-all duration-300">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-xl bg-slate-100 flex items-center justify-center text-2xl">💸</div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-red-600 font-semibold">{comparisonProduct.brand}</p>
            <p class="text-sm font-bold text-slate-800 truncate">{comparisonProduct.name}</p>
            <p class="text-xs text-slate-400">{comparisonProduct.price} EUR · {comparisonProduct.size}</p>
          </div>
          <div class={`grade grade-lg ${gc(comparisonProduct.score)}`}>{comparisonProduct.score}</div>
        </div>
        <div class="space-y-3">
          {subScoreLabels.map((s) => {
            const grade = (comparisonProduct.subScores as any)[s.key] as string;
            const num = gradeToNum(grade);
            return (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs text-slate-600 font-medium">{s.icon} {s.label}</span>
                  <span class={`text-xs font-bold ${gc(grade)}-text`}>{grade}</span>
                </div>
                <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                  <div class="si-score-bar h-full rounded-full transition-all duration-1000" data-width={num} style={`width: 0%; background: ${grade === "A" ? "#10b981" : grade === "B" ? "#3b82f6" : grade === "C" ? "#f59e0b" : "#ef4444"}`}></div>
                </div>
              </div>
            );
          })}
        </div>
        <div class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between">
          <span class="text-2xl font-extrabold text-red-500">{comparisonProduct.scoreNumeric}/100</span>
          <span class="text-xs text-slate-400 group-hover:text-red-600 transition-colors">{locale === "fr" ? "Voir la fiche" : "View details"} &rarr;</span>
        </div>
      </a>
    </div>

    <p class="reveal text-center text-xs text-slate-400 mt-6 max-w-lg mx-auto">
      {locale === "fr"
        ? "CeraVe a 15 EUR obtient un A (88/100). La Mer a 350 EUR obtient un C (67/100). Le prix ne garantit rien. La formule, si."
        : "CeraVe at 15 EUR scores A (88/100). La Mer at 350 EUR scores C (67/100). Price guarantees nothing. The formula does."}
    </p>
  </div>
</section>

<!-- ========== 6. FEATURES ========== -->
<section class="section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <h2 class="reveal text-center mb-10">{t(tr.features.title, locale)}</h2>
    <div class="reveal-children grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
      {(locale === "fr" ? [
        { title: "La v\u00e9rit\u00e9 en 2 secondes", description: "Colle ta liste INCI ou cherche un produit. En 2 secondes, tu sais si \u00e7a vaut ton argent ou si tu paies du marketing.", icon: "zap" },
        { title: "Z\u00e9ro deal avec les marques", description: "On n'accepte pas d'argent des marques. Nos notes viennent des donn\u00e9es UE CosIng, des avis SCCS et de la recherche dermatologique. La Mer obtient un C. On s'en fiche.", icon: "shield" },
